# Environment Variables Reference Template (EcoMatch)
# Copy to .env or service-specific .env files for deployment

# PostgreSQL Configuration
POSTGRES_USER=ecomatch
POSTGRES_PASSWORD=ecomatch
POSTGRES_DB=ecomatch
POSTGRES_PORT=5433

# Service Ports
MS1_PORT=4000
MS2_PORT=8000
FRONTEND_PORT=3000

# Core API (ms1) Configuration
NODE_ENV=production
DATABASE_URL=postgresql://ecomatch:ecomatch@postgres:5432/ecomatch
JWT_SECRET=change-this-to-a-secure-random-secret-key-in-production
MS2_BASE_URL=http://ms2:8000
FRONTEND_URL=https://ecomatch.store

# Agent Service (ms2) Configuration
LOG_LEVEL=info
USE_LLM=true
LLM_MODEL=claude-3-haiku-20240307
LLM_TEMPERATURE=0.7
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
SCOUT_CONFIDENCE_THRESHOLD=0.7
ALCHEMIST_CONFIDENCE_THRESHOLD=0.7

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=https://api.ecomatch.store

# AWS / Cloudinary Credentials (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
